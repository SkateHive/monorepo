# SkateHive Node Configuration
# Copy this file to skatehive.config and customize for your node
# Generated by: ./setup.sh

# =============================================================================
# NODE IDENTITY
# =============================================================================
# A friendly name for this node (used in logs and alerts)
NODE_NAME="my-skatehive-node"

# Node role: "primary", "secondary", or "tertiary"
NODE_ROLE="primary"

# =============================================================================
# TAILSCALE CONFIGURATION
# =============================================================================
# Your Tailscale hostname (e.g., "minivlad.tail83ea3e.ts.net")
# Run: tailscale status --json | jq -r '.Self.DNSName' | sed 's/\.$//'
# Or check: https://login.tailscale.com/admin/machines
TAILSCALE_HOSTNAME=""

# =============================================================================
# SERVICE PORTS (external ports exposed by Docker)
# =============================================================================
VIDEO_TRANSCODER_PORT=8081
INSTAGRAM_DOWNLOADER_PORT=6666

# =============================================================================
# TAILSCALE FUNNEL PATHS
# =============================================================================
# Path prefix for video transcoder (e.g., "/video" -> https://yournode.ts.net/video)
VIDEO_FUNNEL_PATH="/video"
INSTAGRAM_FUNNEL_PATH="/instagram"

# =============================================================================
# PINATA (IPFS) CONFIGURATION
# =============================================================================
# Get your JWT from https://app.pinata.cloud/developers/api-keys
PINATA_JWT=""

# =============================================================================
# HIVE BLOCKCHAIN (Optional)
# =============================================================================
# Only needed for posting features
HIVE_ACCOUNT=""
HIVE_POSTING_KEY=""

# =============================================================================
# OTHER NODES (for multi-node monitoring)
# =============================================================================
# Comma-separated list of other SkateHive nodes for health checks/failover
# Format: "node_id:hostname:role" (role is optional, defaults to "secondary")
# Example: "raspberry:raspberrypi.tail83ea3e.ts.net:secondary,backup:mybackup.ts.net"
OTHER_NODES=""

# Display name for this node (shown in dashboard)
NODE_DISPLAY_NAME=""

# =============================================================================
# ALERTS (Optional)
# =============================================================================
# Discord webhook URL for alerts
DISCORD_WEBHOOK_URL=""

# Email for alerts (requires mailutils)
ALERT_EMAIL=""
